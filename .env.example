# ============================================
# АТЕЛЬЕ "БРИГАДА" - КОНФИГУРАЦИЯ
# ============================================

# === ОБЯЗАТЕЛЬНЫЕ ===

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atelier
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT Secret (обязательно для безопасности!)
# Сгенерируйте случайную строку: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# === ОПЦИОНАЛЬНЫЕ ===

# Server
PORT=5001
NODE_ENV=development

# JWT Token Lifetime (default: 7d)
JWT_EXPIRES_IN=7d

# CORS - URL фронтенда для продакшена
CLIENT_URL=http://localhost:3000

# Frontend URL (для ссылок в email)
FRONTEND_URL=http://localhost:3000

# ============================================
# EMAIL - Resend (для уведомлений и сброса пароля)
# ============================================
# Регистрация: https://resend.com
# Бесплатно: 100 писем/день
#
RESEND_API_KEY=re_xxxxxxxx
FROM_EMAIL=onboarding@resend.dev

# File Upload
# MAX_FILE_SIZE=5242880
# UPLOAD_DIR=./uploads

# Redis (для кэширования, опционально)
# REDIS_URL=redis://localhost:6379

# ============================================
# KASPI PAY (приём платежей)
# ============================================
# Регистрация: https://kaspi.kz/merchant (нужен бизнес аккаунт)
# 
KASPI_MERCHANT_ID=your_merchant_id
KASPI_API_KEY=your_api_key
KASPI_SECRET_KEY=your_secret_key
KASPI_ENV=sandbox  # или 'production'
BACKEND_URL=https://your-app.up.railway.app
