# ============================================
# АТЕЛЬЕ "БРИГАДА" - КОНФИГУРАЦИЯ
# ============================================

# === ОБЯЗАТЕЛЬНЫЕ ===

# PostgreSQL Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atelier
DB_USER=postgres
DB_PASSWORD=your_secure_password_here

# JWT Secret (обязательно для безопасности!)
# Сгенерируйте случайную строку: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# === ОПЦИОНАЛЬНЫЕ ===

# Server
PORT=5001
NODE_ENV=development

# JWT Token Lifetime (default: 7d)
JWT_EXPIRES_IN=7d

# CORS - URL фронтенда для продакшена
CLIENT_URL=http://localhost:3000

# Email/SMS (для уведомлений)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# File Upload
# MAX_FILE_SIZE=5242880
# UPLOAD_DIR=./uploads

# Redis (для кэширования, опционально)
# REDIS_URL=redis://localhost:6379
